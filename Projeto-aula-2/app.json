{
  "expo": {
    "name": "Projeto-aula-2",
    "slug": "Projeto-aula-2",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "projetoaula2",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "server"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
